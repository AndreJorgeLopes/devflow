# Worktrunk configuration for {{PROJECT_NAME}}
# Generated by `devflow init`
#
# Worktrunk manages git worktrees for isolated branch work.
# See: https://github.com/anthropics/worktrunk

[hooks]
# Commands to run after creating a new worktree.
# Use this to install dependencies, copy env files, or run setup scripts.
post_create = ["echo 'Worktree created for {{PROJECT_NAME}}'"]

[step]
# Whether to copy gitignored files (node_modules, .env, build artifacts)
# into new worktrees. Speeds up setup but uses more disk space.
copy_ignored = true
