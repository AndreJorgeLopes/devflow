# Agent Deck configuration for {{PROJECT_NAME}}
# Generated by `devflow init`
#
# Agent Deck orchestrates AI coding agents with unified management.
# Place this file at ~/.config/agent-deck/config.toml or project root.

# ─── Agent Profiles ────────────────────────────────────────────────

[profiles.claude-code]
# Claude Code — default profile
enabled = true
command = "claude"
args = ["--project-dir", "{{PROJECT_ROOT}}"]
default = true

[profiles.opencode]
# OpenCode — alternative agent
enabled = false
command = "opencode"
args = []

# ─── MCP Servers ───────────────────────────────────────────────────

[mcp.hindsight]
# Hindsight — persistent agent memory across sessions
enabled = true
command = "hindsight"
args = ["serve", "--bank", "{{PROJECT_NAME}}"]
# Each agent role can override the bank name (see AGENTS.md)

# Add other MCP servers as needed:
# [mcp.filesystem]
# enabled = true
# command = "mcp-filesystem"
# args = ["--root", "{{PROJECT_ROOT}}"]

# ─── Conductor ─────────────────────────────────────────────────────

[conductor]
# Conductor monitors agent sessions and handles routine interactions
enabled = true

# Automatically respond to confirmation prompts (y/n, proceed, etc.)
auto_confirm = true

# Patterns that trigger auto-confirmation (regex)
auto_confirm_patterns = [
  "^Do you want to proceed",
  "^Continue\\?",
  "^Apply these changes",
]

# Patterns that should NEVER be auto-confirmed (safety rails)
never_confirm_patterns = [
  "force push",
  "delete.*branch",
  "drop.*database",
  "rm -rf",
  "production",
]

# ─── Notifications ─────────────────────────────────────────────────

[notifications]
# Desktop notifications for agent events
enabled = true

# Notify when agent completes a task
on_complete = true

# Notify when agent encounters an error
on_error = true

# Notify when agent needs human input
on_blocked = true

# Notification backend: "system" (native OS), "terminal-notifier", "ntfy"
backend = "system"

# ─── Monitoring ────────────────────────────────────────────────────

[monitoring]
# Enable session monitoring and metrics
enabled = true

# Log agent interactions for review
log_sessions = true

# Session log directory (relative to project root)
log_dir = ".agent-deck/logs"
